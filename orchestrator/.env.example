# ── Orchestrator — Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in all values before running locally.
# In Railway: add these in the Variables tab of your service.

# ── Database (shared with RSE pipeline) ──────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/rse_intelligence

# ── NVIDIA NIM (powers all agents) ───────────────────────────────────────────
# Get free API key at: https://build.nvidia.com → "Get API Key"
NVIDIA_NIM_API_KEY=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

# ── Anthropic Claude (primary agent intelligence + autonomous coding) ─────────
# Get an API key at: https://console.anthropic.com  → add billing credit
# REQUIRED for the 24/7 autonomous build on Railway: agents implement tickets
# unattended via the Anthropic API (a Claude.ai subscription login can't run on
# a headless cloud server, so the API key is what enables "works while you sleep").
# When set, Claude also powers chat (better quality); when blank, chat falls back to NIM.
ANTHROPIC_API_KEY=

# ── Agent model config ────────────────────────────────────────────────────────
# Chat responses — fast and cheap (Haiku)
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
# Ticket implementation — highest coding quality (Sonnet)
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# ── Budget monitoring ─────────────────────────────────────────────────────────
# WhatsApp alert fires at 80%, 100%, 120% of this limit
MONTHLY_BUDGET_USD=20.00

# ── Autonomous build (agents implement tickets continuously, 24/7) ────────────
# Agents work any time of day as long as there's an eligible ticket AND budget.
# They are NOT limited to office hours or night-time — the only governor is spend.
# Master switch. Set to "false" to disable unattended building entirely.
AUTOBUILD_ENABLED=true
# Daily spend cap — paces builds across days so a backlog can't burn the whole
# monthly budget in one go. The worker idles once this is hit and resumes tomorrow.
# Starting conservative at $3/day — watch the Costs tab, then raise once you trust the output.
AUTOBUILD_DAILY_BUDGET_USD=3.00
# Pacing: seconds to wait after a successful build, and seconds to idle when
# there's nothing to do / over budget before re-checking.
AUTOBUILD_PACE_SECONDS=30
AUTOBUILD_IDLE_SECONDS=600
# Per-ticket guards inside the execution loop
EXECUTOR_MAX_ITERS=40
EXECUTOR_COST_CAP_USD=3.00

# ── WhatsApp Outbound (CallMeBot — existing) ──────────────────────────────────
WHATSAPP_PHONE=+250785653763
WHATSAPP_API_KEY=5205291

# ── WhatsApp Inbound (Meta Cloud API — optional, enables 2-way WhatsApp) ─────
# Setup guide: orchestrator/SETUP.md → Step 4
# Leave blank to use web dashboard only for inbound messages.
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_ID=
# This token is used to verify your webhook with Meta (set to any secret string)
WHATSAPP_META_VERIFY_TOKEN=rse-intelligence-verify
