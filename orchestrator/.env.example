# ── Orchestrator — Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in all values before running locally.
# In Railway: add these in the Variables tab of your service.

# ── Database (shared with RSE pipeline) ──────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/rse_intelligence

# ── NVIDIA NIM (powers all agents) ───────────────────────────────────────────
# Get free API key at: https://build.nvidia.com → "Get API Key"
NVIDIA_NIM_API_KEY=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

# ── Anthropic Claude (primary agent intelligence + autonomous coding) ─────────
# Get an API key at: https://console.anthropic.com  → add billing credit
# REQUIRED for the 24/7 autonomous build on Railway: agents implement tickets
# unattended via the Anthropic API (a Claude.ai subscription login can't run on
# a headless cloud server, so the API key is what enables "works while you sleep").
# When set, Claude also powers chat (better quality); when blank, chat falls back to NIM.
ANTHROPIC_API_KEY=

# ── Code-build provider ───────────────────────────────────────────────────────
# Which engine the agents use to IMPLEMENT tickets:
#   nim        → free NVIDIA NIM models (validate the pipeline at ~$0 — START HERE)
#   anthropic  → paid Claude API (best coding quality — switch once it works)
# ANTHROPIC_API_KEY is only required when this is "anthropic".
CODE_PROVIDER=nim
# Coding model(s) for ticket implementation, tried in order (comma-separated).
# Nemotron 3 Ultra is NVIDIA's strongest reasoning/coding model; the Llama entry
# is a fallback used only if the Ultra slug is unavailable or rejects tool calls.
CODE_NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b,meta/llama-3.3-70b-instruct
# Chat/PR-review model chain (NIM) — used by run_agent for conversation, stand-ups,
# and Marcus's PR reviews. Tried in order on 404. Nemotron 3 Ultra leads.
AGENT_NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b,meta/llama-3.3-70b-instruct,meta/llama-3.1-70b-instruct

# ── Agent model config ────────────────────────────────────────────────────────
# Chat responses — fast and cheap (Haiku)
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
# Ticket implementation — highest coding quality (Sonnet), used when CODE_PROVIDER=anthropic
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# ── Budget monitoring ─────────────────────────────────────────────────────────
# WhatsApp alert fires at 80%, 100%, 120% of this limit
MONTHLY_BUDGET_USD=20.00

# ── Autonomous build (agents implement tickets continuously, 24/7) ────────────
# Agents work any time of day as long as there's an eligible ticket AND budget.
# They are NOT limited to office hours or night-time — the only governor is spend.
# Master switch. Set to "false" to disable unattended building entirely.
AUTOBUILD_ENABLED=true
# Daily spend cap — paces builds across days so a backlog can't burn the whole
# monthly budget in one go. The worker idles once this is hit and resumes tomorrow.
# Starting conservative at $3/day — watch the Costs tab, then raise once you trust the output.
AUTOBUILD_DAILY_BUDGET_USD=3.00
# Pacing: seconds to wait after a successful build, and seconds to idle when
# there's nothing to do / over budget before re-checking.
AUTOBUILD_PACE_SECONDS=30
AUTOBUILD_IDLE_SECONDS=600
# Per-ticket guards inside the execution loop
EXECUTOR_MAX_ITERS=40
EXECUTOR_COST_CAP_USD=3.00

# ── GitHub delivery (each agent acts as its own GitHub account) ───────────────
# Without these, agents write code into the container's temporary filesystem and
# it is lost on redeploy. With them, each completed ticket is committed to a new
# branch and opened as a real pull request.
#
# "owner/repo" exactly as on GitHub, e.g. richardmunyemana/rse_intelligence
GITHUB_REPO=
# Base branch PRs target (and branch off from)
GITHUB_BASE_BRANCH=main
#
# PER-AGENT TOKENS — give each agent its OWN GitHub account so commits/PRs come
# from the right person AND the PM can review work he didn't author (GitHub won't
# let an account review its own PR). Each token: classic PAT with 'repo' scope,
# from that agent's account, which must be a collaborator on the repo.
GITHUB_TOKEN_KWAME=     # Backend & AI engineer — authors backend PRs
GITHUB_TOKEN_SOFIA=     # Mobile & Frontend engineer — authors mobile PRs
GITHUB_TOKEN_LUCA=      # DevOps engineer — authors infra/CI PRs
GITHUB_TOKEN_MARCUS=    # Project Manager — REVIEWS/approves the PRs above
GITHUB_TOKEN_ARIA=      # CTO (optional)
# Optional shared fallback used for any agent whose own token is unset.
GITHUB_TOKEN=
# What Marcus does when he reviews: APPROVE, REQUEST_CHANGES, or COMMENT.
PM_REVIEW_EVENT=APPROVE
# Your personal GitHub username — also auto-requested as a reviewer on each PR
# so the final merge decision stays with you.
GITHUB_REVIEWER=

# ── Backlog = GitHub Issues (source of truth) ─────────────────────────────────
# Marcus (PM) opens issues; engineers pick the next eligible one and open a PR
# that closes it. An issue is routed to an engineer by an "agent label":
#   backend → Kwame, mobile/frontend → Sofia, deployment/devops → Luca
# Label applied while an agent is actively building an issue (prevents double-pick):
ISSUE_BUILDING_LABEL=building
# Readiness label Marcus adds to issues that are ready to be worked:
ISSUE_READY_LABEL=agent-ready
# When true, ONLY issues carrying the readiness label are picked up (lets Marcus
# draft issues without them being built until he marks them ready). Default false.
ISSUE_REQUIRE_READY_LABEL=false

# ── WhatsApp Outbound (CallMeBot — existing) ──────────────────────────────────
WHATSAPP_PHONE=+250785653763
WHATSAPP_API_KEY=5205291

# ── WhatsApp Inbound (Meta Cloud API — optional, enables 2-way WhatsApp) ─────
# Setup guide: orchestrator/SETUP.md → Step 4
# Leave blank to use web dashboard only for inbound messages.
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_ID=
# This token is used to verify your webhook with Meta (set to any secret string)
WHATSAPP_META_VERIFY_TOKEN=rse-intelligence-verify
