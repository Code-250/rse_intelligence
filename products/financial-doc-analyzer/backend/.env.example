# Financial Document Analyzer (MVP) — environment variables
# Copy to .env for local runs; in Railway add these in the service Variables tab.

# ── AI analysis (NVIDIA NIM — free tier) ─────────────────────────────────────
# Get a free key at https://build.nvidia.com → "Get API Key"
NVIDIA_NIM_API_KEY=
# Analysis model(s), tried in order on 404. Nemotron 3 Ultra leads.
FDA_ANALYSIS_MODEL=nvidia/nemotron-3-ultra-550b-a55b,meta/llama-3.3-70b-instruct,meta/llama-3.1-70b-instruct

# ── Google Analytics 4 (traffic monitoring) ──────────────────────────────────
# Create a GA4 property → Web data stream → copy the Measurement ID (G-XXXXXXXXXX).
# When set, the page loads GA4 and sends page_view + custom events
# (file_selected, analyze_started, analyze_succeeded, analyze_failed, waitlist_signup).
GA_MEASUREMENT_ID=

# ── First-party stats + waitlist (optional) ──────────────────────────────────
# If set, the app stores waitlist emails and a cookie-less event log (a backup to
# GA4 that ad-blockers can't strip). Leave blank to run without a database.
DATABASE_URL=

# ── Limits ───────────────────────────────────────────────────────────────────
FDA_MAX_FILE_SIZE_MB=15
FDA_MAX_ANALYSIS_CHARS=24000
FDA_RATE_LIMIT_PER_HOUR=20
