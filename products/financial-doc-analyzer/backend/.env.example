# Financial Document Analyzer — Environment Variables
# Copy this file to .env and fill in all values before running.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/rse_intelligence

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FDA_SECRET_KEY=
FDA_ACCESS_TOKEN_EXPIRE_MINUTES=60
FDA_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Document Storage ──────────────────────────────────────────────────────────
FDA_STORAGE_PATH=./data/documents
FDA_MAX_FILE_SIZE_MB=50
FDA_FREE_TIER_MONTHLY_LIMIT=10

# ── NVIDIA NIM (shared with RSE pipeline) ────────────────────────────────────
NVIDIA_NIM_API_KEY=
# Default model for advisory-length docs (≤ 20 pages)
NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# Model for long-form annual reports (> 20 pages, 1M context)
NVIDIA_NIM_LONGDOC_MODEL=deepseek-ai/deepseek-v4-flash

# ── Groq fallback ────────────────────────────────────────────────────────────
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama local fallback ─────────────────────────────────────────────────────
# OLLAMA_MODEL=llama3.2

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave * for local dev)
ALLOWED_ORIGINS=*
