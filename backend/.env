# ── NVIDIA NIM (primary LLM provider) ────────────────────────────────────────
# Get your API key at: https://build.nvidia.com → top-right → "Get API Key"
# Free tier included. No credit card required to start.
NVIDIA_NIM_API_KEY=
# Optional: override the default model (nvidia/llama-3.1-nemotron-70b-instruct)
# Other strong options for financial analysis:
#   nvidia/nemotron-3-super-120b-a12b   (1M context, best for long history)
#   deepseek-ai/deepseek-v4-flash       (fastest, 1M context)
#   mistralai/mistral-medium-3.5-128b   (balanced speed/quality)
NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ── Groq (fallback LLM provider) ─────────────────────────────────────────────
